{{!
    @template local_rewards/my_badges

    Example context (json):
    {
    }
}}

<div class="local-rewards-page">
    <div class="local-rewards-toolbar">
        <div>
            <h1 class="h2 mb-1">{{title}}{{^title}}{{#str}}rewardallbadges, local_rewards{{/str}}{{/title}}</h1>
            <div class="text-muted">{{#str}}rewardintro, local_rewards{{/str}}</div>
        </div>
    </div>

    {{#cards.0}}
        <div class="local-rewards-grid">
            {{#cards}}
                <article class="local-rewards-card">
                    <div class="local-rewards-card__image">
                        <img src="{{imageurl}}" alt="">
                    </div>
                    <div class="local-rewards-card__body">
                        <h2 class="local-rewards-card__title">{{name}}</h2>
                        <div class="local-rewards-card__meta">
                            {{#showstudentname}}<div><strong>{{#str}}rewardstudent, local_rewards{{/str}}:</strong> {{studentname}}</div>{{/showstudentname}}
                            <div><strong>{{#str}}rewardcourse, local_rewards{{/str}}:</strong> {{course}}</div>
                            <div><strong>{{#str}}rewardactivity, local_rewards{{/str}}:</strong> {{activity}}</div>
                            <div><strong>{{#str}}rewardearnedon, local_rewards{{/str}}:</strong> {{timeissued}}</div>
                        </div>
                        <div class="mb-3">{{{description}}}</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary" href="{{viewurl}}">{{#str}}rewardviewbadge, local_rewards{{/str}}</a>
                            <a class="btn btn-outline-primary" href="{{linkedinurl}}" target="_blank" rel="noopener">{{#str}}rewardsharelinkedin, local_rewards{{/str}}</a>
                        </div>
                    </div>
                </article>
            {{/cards}}
        </div>
    {{/cards.0}}

    {{^cards.0}}
        <div class="local-rewards-empty">{{#str}}rewardnobadges, local_rewards{{/str}}</div>
    {{/cards.0}}
</div>
