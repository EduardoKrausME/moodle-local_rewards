{{!
    @template local_rewards/course_badges

    Example context (json):
    {
      "title": "Course Badges",
      "subtitle": "View badges earned by students in this course.",
      "rows": [
        {
          "imageurl": "https://example.com/pluginfile.php/201/local_rewards/badge-1.png",
          "name": "Excellence in Learning",
          "studentname": "John Smith",
          "activity": "Final Project Submission",
          "timeissued": "March 25, 2026",
          "viewurl": "https://example.com/local/rewards/view.php?id=101",
          "linkedinurl": "https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fexample.com%2Flocal%2Frewards%2Fpublic.php%3Fid%3D101"
        },
        {
          "imageurl": "https://example.com/pluginfile.php/202/local_rewards/badge-2.png",
          "name": "Perfect Attendance",
          "studentname": "Emily Johnson",
          "activity": "Course Attendance",
          "timeissued": "March 20, 2026",
          "viewurl": "https://example.com/local/rewards/view.php?id=102",
          "linkedinurl": "https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fexample.com%2Flocal%2Frewards%2Fpublic.php%3Fid%3D102"
        },
        {
          "imageurl": "https://example.com/pluginfile.php/203/local_rewards/badge-3.png",
          "name": "Team Collaboration",
          "studentname": "Michael Brown",
          "activity": "Group Assignment",
          "timeissued": "March 18, 2026",
          "viewurl": "https://example.com/local/rewards/view.php?id=103",
          "linkedinurl": "https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fexample.com%2Flocal%2Frewards%2Fpublic.php%3Fid%3D103"
        }
      ]
    }
}}
<div class="local-rewards-page">
    <div class="local-rewards-toolbar">
        <div>
            <h1 class="h2 mb-1">{{title}}</h1>
            <div class="text-muted">{{subtitle}}</div>
        </div>
    </div>

    {{#rows}}
        <div class="local-rewards-table card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{#str}}rewardbadge, local_rewards{{/str}}</th>
                            <th>{{#str}}rewardstudent, local_rewards{{/str}}</th>
                            <th>{{#str}}rewardactivity, local_rewards{{/str}}</th>
                            <th>{{#str}}rewardearnedon, local_rewards{{/str}}</th>
                            <th class="text-end">{{#str}}rewardbankactions, local_rewards{{/str}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#rows}}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img class="local-rewards-table__thumb" src="{{imageurl}}" alt="">
                                        <div>
                                            <div class="fw-semibold">{{name}}</div>
                                        </div>
                                    </div>
                                </td>
                                <td>{{studentname}}</td>
                                <td>{{activity}}</td>
                                <td>{{timeissued}}</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a class="btn btn-sm btn-outline-primary" href="{{viewurl}}">{{#str}}rewardviewbadge, local_rewards{{/str}}</a>
                                        <a class="btn btn-sm btn-primary" href="{{linkedinurl}}" target="_blank" rel="noopener">{{#str}}rewardsharelinkedin, local_rewards{{/str}}</a>
                                    </div>
                                </td>
                            </tr>
                        {{/rows}}
                    </tbody>
                </table>
            </div>
        </div>
    {{/rows}}

    {{^rows}}
        <div class="local-rewards-empty">{{#str}}rewardnocoursebadges, local_rewards{{/str}}</div>
    {{/rows}}
</div>
