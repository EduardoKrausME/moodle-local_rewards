{{!
    @template local_rewards/bank

    Example context (json):
    {
      "createurl": "https://example.com/local/rewards/edit.php",
      "cards": [
        {
          "imageurl": "https://example.com/pluginfile.php/101/local_rewards/badge-1.png",
          "name": "Excellence in Learning",
          "description": "<p>This badge is awarded to students who demonstrate outstanding engagement and achievement in course activities.</p>",
          "editurl": "https://example.com/local/rewards/edit.php?id=1",
          "deleteurl": "https://example.com/local/rewards/delete.php?id=1",
          "deletelabel": "Are you sure you want to delete this badge?"
        },
        {
          "imageurl": "https://example.com/pluginfile.php/102/local_rewards/badge-2.png",
          "name": "Project Completion",
          "description": "<p>This badge recognizes successful completion of the final project with all required criteria met.</p>",
          "editurl": "https://example.com/local/rewards/edit.php?id=2",
          "deleteurl": "https://example.com/local/rewards/delete.php?id=2",
          "deletelabel": "Are you sure you want to delete this badge?"
        }
      ]
    }
}}
<div class="local-rewards-page">
    <div class="local-rewards-toolbar">
        <div>
            <h1 class="h2 mb-1">{{#str}}rewardbanktitle, local_rewards{{/str}}</h1>
            <div class="text-muted">{{#str}}rewardbanksubtitle, local_rewards{{/str}}</div>
        </div>
        <a class="btn btn-primary" href="{{createurl}}">{{#str}}rewardcreatebadge, local_rewards{{/str}}</a>
    </div>

    {{#cards}}
        <div class="local-rewards-grid">
            {{#cards}}
                <article class="local-rewards-card">
                    <div class="local-rewards-card__image">
                        <img src="{{imageurl}}" alt="">
                    </div>
                    <div class="local-rewards-card__body">
                        <h2 class="local-rewards-card__title">{{name}}</h2>
                        <div class="mb-3">{{{description}}}</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary" href="{{editurl}}">{{#str}}rewardeditbadge, local_rewards{{/str}}</a>
                            <a class="btn btn-outline-danger"
                               href="{{deleteurl}}"
                               onclick="return confirm('{{deletelabel}}');">{{#str}}rewarddelete, local_rewards{{/str}}</a>
                        </div>
                    </div>
                </article>
            {{/cards}}
        </div>
    {{/cards}}

    {{^cards}}
        <div class="local-rewards-empty">{{#str}}rewardbankempty, local_rewards{{/str}}</div>
    {{/cards}}
</div>
